<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Mac App Store smoke-test entitlements.

  This is intentionally narrower than the Developer ID hardened-runtime
  entitlements: the App Store build must be sandboxed, and the direct
  distribution DYLD exception is not appropriate here.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <!-- Outbound HTTPS remains required for live quota and pricing requests. -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
