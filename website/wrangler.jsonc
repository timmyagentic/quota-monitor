{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "quota-monitor-site",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-15",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": [
      "/download",
      "/api/release",
      "/api/v1/daily-active",
      "/maintainer/versions"
    ]
  },
  "d1_databases": [
    {
      "binding": "VERSION_STATS_DB",
      "database_name": "quota-monitor-version-stats",
      "migrations_dir": "migrations"
    }
  ],
  "ratelimits": [
    {
      "name": "DAILY_ACTIVE_RATE_LIMITER",
      "namespace_id": "2026071601",
      "simple": {
        "limit": 120,
        "period": 60
      }
    },
    {
      "name": "DAILY_ACTIVE_GLOBAL_RATE_LIMITER",
      "namespace_id": "2026071602",
      "simple": {
        "limit": 5000,
        "period": 60
      }
    },
    {
      "name": "ADMIN_VERSION_STATS_RATE_LIMITER",
      "namespace_id": "2026071603",
      "simple": {
        "limit": 30,
        "period": 60
      }
    }
  ],
  "triggers": {
    "crons": ["15 * * * *"]
  },
  "routes": [
    {
      "pattern": "quota-monitor.timmyagentic.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": false,
    "logs": {
      "enabled": false,
      "invocation_logs": false,
      "persist": false
    }
  }
}
